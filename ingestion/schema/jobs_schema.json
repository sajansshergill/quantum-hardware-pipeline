{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QPU Job Execution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "device_id",
    "user_id",
    "circuit_depth",
    "num_shots",
    "queue_wait_seconds",
    "exec_time_seconds",
    "total_time_seconds",
    "status",
    "error_code",
    "sla_met",
    "timestamp"
  ],
  "properties": {
    "job_id": {"type": "string", "format": "uuid"},
    "device_id": {"type": "string", "minLength": 1},
    "user_id": {"type": "string", "pattern": "^user_[0-9a-f]{8}$"},
    "circuit_depth": {"type": "integer", "minimum": 1},
    "num_shots": {"type": "integer", "minimum": 1},
    "queue_wait_seconds": {"type": "number", "minimum": 0.0},
    "exec_time_seconds": {"type": "number", "minimum": 0.0},
    "total_time_seconds": {"type": "number", "minimum": 0.0},
    "status": {"type": "string", "enum": ["completed", "failed", "cancelled", "timeout"]},
    "error_code": {"type": ["string", "null"]},
    "sla_met": {"type": "boolean"},
    "timestamp": {"type": "string", "format": "date-time"}
  }
}
